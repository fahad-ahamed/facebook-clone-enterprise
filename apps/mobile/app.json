{
  "expo": {
    "name": "Facebook Clone",
    "slug": "facebook-clone-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.facebookclone.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera for photos and videos",
        "NSPhotoLibraryUsageDescription": "Allow photo library access"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1877F2"
      },
      "package": "com.facebookclone.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000",
      "wsUrl": "ws://localhost:4001"
    }
  }
}
